---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'プライバシーポリシー | DevTools',
  url: new URL('/privacy', Astro.site).href,
  description: 'DevTools のプライバシーポリシー',
  inLanguage: 'ja',
};

const lastUpdated = '2026年4月12日';
---

<BaseLayout
  title="プライバシーポリシー"
  description="DevTools のプライバシーポリシー"
  jsonLd={jsonLd}
>
  <main class="mx-auto max-w-2xl px-6 py-12" id="main-content">
    <h1
      class="mb-2 font-bold text-neutral-900"
      style="font-size: 1.75rem; line-height: 1.4; letter-spacing: 0.02em;"
    >
      プライバシーポリシー
    </h1>
    <p
      class="mb-10 text-neutral-500"
      style="font-size: 0.875rem; line-height: 1.7; letter-spacing: 0.02em;"
    >
      最終更新: {lastUpdated}
    </p>

    <section class="mb-10">
      <h2
        class="mb-3 font-bold text-neutral-900"
        style="font-size: 1.125rem; line-height: 1.5; letter-spacing: 0.02em;"
      >
        データの収集について
      </h2>
      <p
        class="text-neutral-700"
        style="font-size: 1rem; line-height: 1.8; letter-spacing: 0.02em;"
      >
        DevTools は、いかなる個人情報・入力データも収集・保存・送信しません。
        すべての処理はお使いのブラウザ内で完結し、入力した内容が外部サーバーに送信されることはありません。
      </p>
    </section>

    <section class="mb-10">
      <h2
        class="mb-3 font-bold text-neutral-900"
        style="font-size: 1.125rem; line-height: 1.5; letter-spacing: 0.02em;"
      >
        Cookie・ローカルストレージ
      </h2>
      <p
        class="text-neutral-700"
        style="font-size: 1rem; line-height: 1.8; letter-spacing: 0.02em;"
      >
        本サービスは Cookie を使用していません。
        ローカルストレージへの保存も現時点では行っておりません。
      </p>
    </section>

    <section class="mb-10">
      <h2
        class="mb-3 font-bold text-neutral-900"
        style="font-size: 1.125rem; line-height: 1.5; letter-spacing: 0.02em;"
      >
        アクセス解析・広告
      </h2>
      <p
        class="text-neutral-700"
        style="font-size: 1rem; line-height: 1.8; letter-spacing: 0.02em;"
      >
        アクセス解析ツール・広告サービス・サードパーティのトラッキングスクリプトは一切使用していません。
      </p>
    </section>

    <section class="mb-10">
      <h2
        class="mb-3 font-bold text-neutral-900"
        style="font-size: 1.125rem; line-height: 1.5; letter-spacing: 0.02em;"
      >
        ホスティング
      </h2>
      <p
        class="text-neutral-700"
        style="font-size: 1rem; line-height: 1.8; letter-spacing: 0.02em;"
      >
        本サービスは Cloudflare Pages でホストされています。
        Cloudflare のサーバーはリクエストに伴う標準的なサーバーログ（IPアドレス等）を一時的に記録する場合があります。
        詳しくは <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer" class="text-link underline hover:no-underline">Cloudflare のプライバシーポリシー</a> をご参照ください。
      </p>
    </section>

    <section>
      <h2
        class="mb-3 font-bold text-neutral-900"
        style="font-size: 1.125rem; line-height: 1.5; letter-spacing: 0.02em;"
      >
        ポリシーの変更
      </h2>
      <p
        class="text-neutral-700"
        style="font-size: 1rem; line-height: 1.8; letter-spacing: 0.02em;"
      >
        本ポリシーを変更する場合は、このページを更新します。
      </p>
    </section>
  </main>
</BaseLayout>
