---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tools, categoryLabel, categoryColor, type ToolCategory } from '../data/tools';

const categories: ToolCategory[] = ['generate', 'convert'];
---

<BaseLayout title="無料オンライン開発者ツール集" description="ブラウザで完結する無料の開発者ツール集。URLエンコード、JWTデコード、ULID生成など。">
  <!-- ヒーロー (黒背景) -->
  <section class="bg-black text-white text-center px-4 py-10">
    <!-- Section Heading: 40px, weight 600, line-height 1.10 -->
    <h1 class="mb-2" style="font-size: 2.5rem; font-weight: 600; line-height: 1.10; letter-spacing: -0.28px;">
      DevTools
    </h1>
    <!-- Body: 17px, weight 400, line-height 1.47, tracking -0.374px -->
    <p class="mb-4" style="font-size: 1.06rem; font-weight: 400; line-height: 1.47; letter-spacing: -0.374px; color: rgba(255,255,255,0.8);">
      ブラウザで完結する無料の開発者ツール集
    </p>
    <!-- Micro: 12px -->
    <div class="flex flex-wrap justify-center gap-4" style="font-size: 0.75rem; line-height: 1.33; letter-spacing: -0.12px; color: rgba(255,255,255,0.48);">
      <span>データはブラウザ内のみ</span>
      <span>インストール不要</span>
      <span>完全無料・登録不要</span>
    </div>
  </section>

  <!-- ツール一覧 -->
  <main class="mx-auto max-w-7xl px-4 py-8">
    {categories.map((cat) => (
      <section class="mb-12">
        <!-- Micro Bold: 12px, weight 600, line-height 1.33, tracking -0.12px -->
        <h2 class="mb-6 uppercase" style="font-size: 0.75rem; font-weight: 600; line-height: 1.33; letter-spacing: 0.08em; color: rgba(0,0,0,0.48);">
          {categoryLabel[cat]}ツール
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {tools.filter((t) => t.category === cat).map((tool) => (
            <a
              href={`/tools/${tool.slug}`}
              class="group rounded-lg bg-white p-6 transition-colors block border border-transparent hover:border-accent"
            >
              <div class="mb-4 flex items-start justify-between">
                <span style="font-size: 1.5rem;">{tool.icon}</span>
                <!-- Caption: 12px -->
                <span class="rounded-full px-2 py-0.5" style="font-size: 0.75rem; font-weight: 500; background: #f5f5f7; color: rgba(0,0,0,0.48);">
                  {categoryLabel[tool.category]}
                </span>
              </div>
              <!-- Sub-heading: 21px, weight 400, line-height 1.19, tracking 0.231px -->
              <h3 class="mb-2 text-apple-dark group-hover:text-accent transition-colors" style="font-size: 1.31rem; font-weight: 400; line-height: 1.19; letter-spacing: 0.231px;">
                {tool.name}
              </h3>
              <!-- Caption: 14px, line-height 1.29, tracking -0.224px -->
              <p class="mb-4" style="font-size: 0.875rem; line-height: 1.29; letter-spacing: -0.224px; color: rgba(0,0,0,0.48);">{tool.description}</p>
              <!-- Link: 14px, tracking -0.224px, color #0066cc -->
              <span class="transition-colors" style="font-size: 0.875rem; line-height: 1.43; letter-spacing: -0.224px; color: #0066cc;">
                開く &rsaquo;
              </span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </main>
</BaseLayout>
