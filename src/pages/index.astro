---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tools, categoryLabel, categoryColor, type ToolCategory } from '../data/tools';

const categories: ToolCategory[] = ['generate', 'convert'];
---

<BaseLayout title="無料オンライン開発者ツール集" description="ブラウザで完結する無料の開発者ツール集。URLエンコード、JWTデコード、ULID生成など。">
  <main class="mx-auto max-w-screen-xl px-4 py-12">
    <!-- ヒーロー -->
    <section class="mb-12 text-center">
      <h1 class="mb-3 text-4xl font-bold tracking-tight text-gray-900 dark:text-white">
        DevTools
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        ブラウザで完結する無料の開発者ツール集
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-6 text-sm text-gray-500 dark:text-gray-400">
        <span>🔒 データはブラウザ内のみ</span>
        <span>⚡ インストール不要</span>
        <span>🆓 完全無料・登録不要</span>
      </div>
    </section>

    <!-- ツール一覧 -->
    {categories.map((cat) => (
      <section class="mb-10">
        <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">
          {categoryLabel[cat]}ツール
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {tools.filter((t) => t.category === cat).map((tool) => (
            <a
              href={`/tools/${tool.slug}`}
              class="group rounded-xl border border-gray-200 bg-white p-5 transition-shadow hover:shadow-md dark:border-gray-800 dark:bg-gray-900 dark:hover:border-gray-600"
            >
              <div class="mb-3 flex items-start justify-between">
                <span class="text-2xl">{tool.icon}</span>
                <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${categoryColor[tool.category]}`}>
                  {categoryLabel[tool.category]}
                </span>
              </div>
              <h3 class="mb-1 font-semibold text-gray-900 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400">
                {tool.name}
              </h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">{tool.description}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </main>
</BaseLayout>
