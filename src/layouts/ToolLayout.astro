---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import { categoryLabel, categoryColor } from '../data/tools';
import type { Tool } from '../data/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
---

<BaseLayout title={tool.name} description={tool.description}>
  <div class="mx-auto flex max-w-screen-xl gap-6 px-4 py-6">
    <!-- サイドバー (デスクトップ) -->
    <div class="hidden lg:block">
      <Sidebar currentSlug={tool.slug} />
    </div>

    <!-- メインコンテンツ -->
    <main class="min-w-0 flex-1" id="main-content">
      <!-- パンくずリスト: Caption 14px, tracking -0.224px -->
      <nav aria-label="パンくずリスト" class="mb-4 flex items-center gap-1.5" style="font-size: 0.875rem; line-height: 1.29; letter-spacing: -0.224px; color: rgba(0,0,0,0.48);">
        <a href="/" class="hover:text-[#0071e3] transition-colors">ホーム</a>
        <span>/</span>
        <span>{categoryLabel[tool.category]}</span>
        <span>/</span>
        <span class="text-[#1d1d1f] dark:text-white">{tool.name}</span>
      </nav>

      <!-- ツールヘッダー -->
      <div class="mb-6 flex items-center gap-3">
        <span style="font-size: 2rem;">{tool.icon}</span>
        <div>
          <!-- Tile Heading: 28px, weight 400, line-height 1.14, tracking 0.196px -->
          <h1 class="text-[#1d1d1f] dark:text-white" style="font-size: 1.75rem; font-weight: 400; line-height: 1.14; letter-spacing: 0.196px;">{tool.name}</h1>
          <!-- Caption: 14px, weight 400, line-height 1.29, tracking -0.224px -->
          <p class="mt-1" style="font-size: 0.875rem; line-height: 1.29; letter-spacing: -0.224px; color: rgba(0,0,0,0.48);">{tool.description}</p>
        </div>
        <span class="ml-auto rounded-full px-2.5 py-0.5" style="font-size: 0.75rem; font-weight: 500; background: #f5f5f7; color: rgba(0,0,0,0.48);">
          {categoryLabel[tool.category]}
        </span>
      </div>

      <!-- ツール本体 -->
      <slot />
    </main>
  </div>
</BaseLayout>
