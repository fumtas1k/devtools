---
interface Props {
  slug: string;
  size?: number;
  class?: string;
}

const { slug, size = 24, class: className = '' } = Astro.props;

const attrs = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '2',
  'stroke-linecap': 'round' as const,
  'stroke-linejoin': 'round' as const,
  'aria-hidden': true,
  class: className,
};
---

{
  slug === 'url-encode' && (
    <svg {...attrs}>
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
    </svg>
  )
}

{
  slug === 'jwt-decoder' && (
    <svg {...attrs}>
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
    </svg>
  )
}

{
  slug === 'ulid-generator' && (
    <svg {...attrs}>
      <line x1="4" y1="9" x2="20" y2="9" />
      <line x1="4" y1="15" x2="20" y2="15" />
      <line x1="10" y1="3" x2="8" y2="21" />
      <line x1="16" y1="3" x2="14" y2="21" />
    </svg>
  )
}

{
  slug === 'dummy-text' && (
    <svg {...attrs}>
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
      <polyline points="14 2 14 8 20 8" />
      <line x1="16" y1="13" x2="8" y2="13" />
      <line x1="16" y1="17" x2="8" y2="17" />
      <line x1="10" y1="9" x2="8" y2="9" />
    </svg>
  )
}

{
  slug === 'qr-code' && (
    <svg {...attrs}>
      <rect x="3" y="3" width="7" height="7" rx="1" />
      <rect x="14" y="3" width="7" height="7" rx="1" />
      <rect x="3" y="14" width="7" height="7" rx="1" />
      <rect x="5" y="5" width="3" height="3" fill="currentColor" stroke="none" />
      <rect x="16" y="5" width="3" height="3" fill="currentColor" stroke="none" />
      <rect x="5" y="16" width="3" height="3" fill="currentColor" stroke="none" />
      <path d="M14 14h3v3h-3z" />
      <path d="M18 14h3v3h-3z" />
      <path d="M14 18h3v3h-3z" />
      <path d="M18 18h3v3h-3z" />
    </svg>
  )
}

{
  slug === 'gs1-databar' && (
    <svg {...attrs} stroke-width="1.5">
      {/* Linear barcode part */}
      <line x1="3" y1="8" x2="3" y2="17" />
      <line x1="5" y1="8" x2="5" y2="17" stroke-width="2.5" />
      <line x1="7" y1="8" x2="7" y2="17" />
      <line x1="9" y1="8" x2="9" y2="17" stroke-width="2.5" />
      <line x1="11" y1="8" x2="11" y2="17" />
      <line x1="13" y1="8" x2="13" y2="17" stroke-width="2.5" />
      <line x1="15" y1="8" x2="15" y2="17" />
      <line x1="17" y1="8" x2="17" y2="17" stroke-width="2.5" />
      <line x1="19" y1="8" x2="19" y2="17" />
      <line x1="21" y1="8" x2="21" y2="17" />
      {/* Composite 2D part (dots above barcode) */}
      <rect x="4" y="3" width="2" height="2" fill="currentColor" stroke="none" />
      <rect x="8" y="3" width="2" height="2" fill="currentColor" stroke="none" />
      <rect x="13" y="3" width="2" height="2" fill="currentColor" stroke="none" />
      <rect x="17" y="3" width="2" height="2" fill="currentColor" stroke="none" />
    </svg>
  )
}

{
  slug === 'jan-code' && (
    <svg {...attrs} stroke-width="1.5">
      <line x1="3" y1="5" x2="3" y2="19" />
      <line x1="5" y1="5" x2="5" y2="19" stroke-width="3" />
      <line x1="8" y1="5" x2="8" y2="19" />
      <line x1="10" y1="5" x2="10" y2="19" />
      <line x1="12" y1="5" x2="12" y2="19" stroke-width="3" />
      <line x1="15" y1="5" x2="15" y2="19" />
      <line x1="17" y1="5" x2="17" y2="19" stroke-width="3" />
      <line x1="20" y1="5" x2="20" y2="19" />
      <line x1="22" y1="5" x2="22" y2="19" />
    </svg>
  )
}
