---
import { tools, categoryLabel, categoryColor, type ToolCategory } from '../../data/tools';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const categories: ToolCategory[] = ['generate', 'convert'];
---

<aside class="w-56 shrink-0">
  <nav aria-label="ツール一覧">
    {categories.map((cat) => (
      <div class="mb-4">
        <h2 class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider" style="color: rgba(0,0,0,0.48);">
          {categoryLabel[cat]}
        </h2>
        <ul>
          {tools.filter((t) => t.category === cat).map((tool) => (
            <li>
              <a
                href={`/tools/${tool.slug}`}
                aria-current={currentSlug === tool.slug ? 'page' : undefined}
                class={`flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm transition-colors
                  ${currentSlug === tool.slug
                    ? 'font-medium text-[#0071e3] bg-white'
                    : 'text-[#1d1d1f] hover:bg-white dark:text-white dark:hover:bg-[#272729]'
                  }`}
              >
                <span>{tool.icon}</span>
                <span>{tool.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>
