---
---

<header class="sticky top-0 z-50 h-12" style="background: rgba(0,0,0,0.8); backdrop-filter: saturate(180%) blur(20px);">
  <div class="mx-auto flex h-12 max-w-screen-xl items-center justify-between px-4">
    <a href="/" class="text-sm font-semibold text-white hover:opacity-80 transition-opacity">
      DevTools
    </a>

    <button
      id="theme-toggle"
      aria-label="ダークモード切替"
      class="rounded-md p-2 text-white/70 hover:text-white transition-colors text-sm"
    >
      <span id="theme-icon-light" class="hidden dark:block">☀️</span>
      <span id="theme-icon-dark" class="block dark:hidden">🌙</span>
    </button>
  </div>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  const html = document.documentElement;

  const saved = localStorage.getItem('theme');
  if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    html.classList.add('dark');
  }

  btn?.addEventListener('click', () => {
    html.classList.toggle('dark');
    localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
  });
</script>
